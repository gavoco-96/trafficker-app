{
  "crons": [
    {
      "path": "/api/cron-send-reports",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-daily-report",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/r/:slug", "destination": "/api/r/[slug]" },
    { "source": "/privacidad", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terminos", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" }
  ]
}
